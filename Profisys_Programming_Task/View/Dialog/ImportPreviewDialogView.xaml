<Window x:Class="Profisys_Programming_Task.View.Dialog.ImportPreviewDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Profisys_Programming_Task.View.Dialog"
             xmlns:viewmodel="clr-namespace:Profisys_Programming_Task.ViewModel.DialogViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:DocumentsImportPreviewDialogViewModel}"
             mc:Ignorable="d" 
             Title="Imported data view" Height="450" Width="800">
    <StackPanel Orientation="Vertical" Background="White">
        <Label FontSize="24" HorizontalAlignment="Center" Margin="5">Documents loaded from file</Label>
        <DataGrid Height="300" Margin="10"
        ItemsSource="{Binding Items}" 
        SelectedItem="{Binding SelectedItem}"
        CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
        AutoGenerateColumns="True">
        </DataGrid>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
        <Button Height="20" Width="50" Command="{Binding DeleteItemCommand}">Delete</Button>
            <Button Height="20" Width="50" Margin="15,0,15,0" Command="{Binding AcceptImportCommand}">Accept</Button>
            <Button Height="20" Width="50" Command="{Binding CancelImportCommand}">Cancel</Button>
    </StackPanel>
    </StackPanel>
</Window>
