<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#ff7500</Color>
    <Color x:Key="SecondaryColor">#b4876d</Color>
    <Color x:Key="AccentColor">#64676E</Color>
    <Color x:Key="BackgroundColor">#E5E4E2</Color>
    <Color x:Key="SecondaryBackgroundColor">#F2F0EF</Color>
    <Color x:Key="ErrorColor">#FFB71C1C</Color>
    <Color x:Key="SuccesColor">#00b93f</Color>

    <Color x:Key="TextPrimaryColor">#000000</Color>
    <Color x:Key="TextSecondaryColor">#FFFFFF</Color>

    <Color x:Key="DataGirdCellFocusBorderColor">#FFFFFFFF</Color>

    <SolidColorBrush  x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush  x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush  x:Key="AccentColorBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush  x:Key="BackgroundColorBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush  x:Key="SecondaryBackgroundColorBrush" Color="{StaticResource SecondaryBackgroundColor}"/>
    <SolidColorBrush  x:Key="ErrorColorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush  x:Key="SuccesColorBrush" Color="{StaticResource SuccesColor}"/>

    <SolidColorBrush  x:Key="TextPrimaryColorrBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush  x:Key="TextSecondaryColorBrush" Color="{StaticResource TextSecondaryColor}"/>

    <SolidColorBrush x:Key="DataGirdCellFocusBorderColorBrush" Color="{StaticResource DataGirdCellFocusBorderColor}"/>

</ResourceDictionary>