<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ControlTemplate x:Key="ExpanderToggleButtonTemplate" TargetType="ToggleButton">
        <Border Background="{TemplateBinding Background}"
            Padding="{TemplateBinding Padding}">
            <DockPanel LastChildFill="True">
                <!-- Strzałka -->
                <Path x:Name="Arrow"
                  Fill="{DynamicResource TextPrimaryColorrBrush}"
                  Width="12" Height="12"
                  Stretch="Uniform"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  Data="M 0 0 L 8 4 L 0 8 Z" />

                <!-- Header Text -->
                <ContentPresenter VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- TRIGGERS for rotation -->
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Arrow" Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="90" CenterX="6" CenterY="6"/>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentColorBrush}" />
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryColorBrush}" />
            </Trigger>

            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.3" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="Expander">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundColorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryColorrBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColorBrush}" />
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                        <DockPanel>
                            <!-- Header (Clickable Area) -->
                            <ToggleButton x:Name="ExpanderToggle"
                                      Background="Transparent"
                                      Foreground="{TemplateBinding Foreground}"
                                      Cursor="Hand"
                                      DockPanel.Dock="Top"
                                      Padding="10,5"
                                      FontWeight="Bold"
                                      Content="{TemplateBinding Header}"
                                      Template="{StaticResource ExpanderToggleButtonTemplate}"/>

                            <!-- Content (Expanded Area) -->
                            <ContentPresenter x:Name="ExpandSite"
                                          Margin="10"
                                          Visibility="Collapsed" />
                        </DockPanel>
                    </Border>

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="ExpanderToggle" Property="IsChecked" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ExpanderToggle" Property="Background" Value="{DynamicResource AccentColorBrush}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    
</ResourceDictionary>